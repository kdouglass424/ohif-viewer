{
  "Name": "ohif-dev-orthanc",
  "HttpPort": 8042,
  "DicomPort": 4242,

  "AuthenticationEnabled": false,
  "RemoteAccessAllowed": true,

  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web/"
  },

  "PostgreSQL": {
    "EnableIndex": true,
    "EnableStorage": false,
    "Host": "postgres",
    "Port": 5432,
    "Database": "orthanc",
    "Username": "postgres",
    "Password": "postgres",
    "EnableSsl": false
  },

  "AwsS3Storage": {
    "BucketName": "dicom-storage",
    "Region": "us-east-1",
    "Endpoint": "http://minio:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "VirtualAddressing": false,
    "EnableLegacyStorageStructure": false
  },

  "LuaScripts": [
    "/etc/orthanc/on-stored-instance.lua"
  ]
}
